{
  "rules": [],
  "_examples": [
    {
      "id": "no-prod-db-drops",
      "block": "DROP\\s+(TABLE|DATABASE)",
      "message": "Refuse DROP statements against production schemas. Use additive migrations."
    },
    {
      "id": "no-secret-commit",
      "block": "(AKIA[0-9A-Z]{16}|-----BEGIN (RSA|OPENSSH) PRIVATE KEY-----)",
      "message": "Refuse to commit AWS access keys or private keys."
    }
  ]
}
